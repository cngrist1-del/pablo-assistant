    <script>
        // Data Store (Local Storage)
        let leads = JSON.parse(localStorage.getItem('falcons_leads')) || [];
        let appointments = JSON.parse(localStorage.getItem('falcons_appointments')) || [];
        let currentFilter = 'all';
        
        // Initialize
        document.addEventListener('DOMContentLoaded', () => {
            renderStats();
            renderLeads();
            setupNav();
        });
        
        // Navigation
        function setupNav() {
            document.querySelectorAll('.nav-item[data-filter]').forEach(item => {
                item.addEventListener('click', () => {
                    document.querySelectorAll('.nav-item').forEach(i => i.classList.remove('active'));
                    item.classList.add('active');
                    currentFilter = item.dataset.filter;
                    document.getElementById('pageTitle').textContent = item.querySelector('span').textContent;
                    renderLeads();
                });
            });
        }
        
        // Render Stats
        function renderStats() {
            document.getElementById('totalLeads').textContent = leads.length;
            document.getElementById('scorchingLeads').textContent = leads.filter(l => l.status === 'scorching').length;
            document.getElementById('hotLeads').textContent = leads.filter(l => l.status === 'hot').length;
            document.getElementById('appointments').textContent = appointments.length;
            document.getElementById('closures').textContent = leads.filter(l => l.status === 'closed').length;
            
            // Update badges
            document.getElementById('allBadge').textContent = leads.length;
            document.getElementById('scorchingBadge').textContent = leads.filter(l => l.status === 'scorching').length;
            document.getElementById('hotBadge').textContent = leads.filter(l => l.status === 'hot').length;
            document.getElementById('warmBadge').textContent = leads.filter(l => l.status === 'warm').length;
            document.getElementById('coldBadge').textContent = leads.filter(l => l.status === 'cold').length;
            document.getElementById('appointmentBadge').textContent = leads.filter(l => l.status === 'appointment').length;
            document.getElementById('closedBadge').textContent = leads.filter(l => l.status === 'closed').length;
        }
        
        // Render Leads
        function renderLeads() {
            const searchTerm = document.getElementById('searchInput').value.toLowerCase();
            let filteredLeads = leads;
            
            // Apply filter
            if (currentFilter !== 'all') {
                filteredLeads = leads.filter(l => l.status === currentFilter);
            }
            
            // Apply search
            if (searchTerm) {
                filteredLeads = filteredLeads.filter(l => 
                    l.name.toLowerCase().includes(searchTerm) ||
                    (l.phone && l.phone.includes(searchTerm)) ||
                    (l.email && l.email.toLowerCase().includes(searchTerm))
                );
            }
            
            const grid = document.getElementById('leadGrid');
            
            if (filteredLeads.length === 0) {
                grid.innerHTML = `
                    <div class="empty-state">
                        <h3>No leads found</h3>
                        <p>Add a new lead or adjust your filters</p>
                    </div>
                `;
                return;
            }
            
            grid.innerHTML = filteredLeads.map(lead => `
                <div class="lead-card ${lead.status}">
                    <div class="lead-header">
                        <div class="lead-name">${lead.name}</div>
                        <span class="lead-status ${lead.status}">${formatStatus(lead.status)}</span>
                    </div>
                    <div class="lead-info">
                        <div class="lead-info-item">
                            <label>Phone</label>
                            <span>${lead.phone || '-'}</span>
                        </div>
                        <div class="lead-info-item">
                            <label>Email</label>
                            <span>${lead.email || '-'}</span>
                        </div>
               