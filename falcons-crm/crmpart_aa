<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Falcons Fury HD - BDC CRM</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, sans-serif;
        }
        
        :root {
            --primary: #1a1a1a;
            --secondary: #c41e3a;
            --accent: #f97316;
            --success: #22c55e;
            --warning: #eab308;
            --danger: #ef4444;
            --bg: #0f0f0f;
            --card: #1a1a1a;
            --border: #2a2a2a;
            --text: #ffffff;
            --text-muted: #a1a1a1;
        }
        
        body {
            background: var(--bg);
            color: var(--text);
            min-height: 100vh;
        }
        
        /* Header */
        .header {
            background: var(--primary);
            padding: 1rem 2rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 2px solid var(--secondary);
        }
        
        .logo {
            font-size: 1.5rem;
            font-weight: bold;
            color: var(--text);
        }
        
        .logo span {
            color: var(--secondary);
        }
        
        .user-info {
            display: flex;
            align-items: center;
            gap: 1rem;
        }
        
        /* Stats Bar */
        .stats-bar {
            display: grid;
            grid-template-columns: repeat(5, 1fr);
            gap: 1rem;
            padding: 1rem 2rem;
            background: var(--card);
        }
        
        .stat-card {
            background: var(--border);
            padding: 1rem;
            border-radius: 8px;
            text-align: center;
        }
        
        .stat-card h3 {
            font-size: 0.75rem;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 1px;
        }
        
        .stat-card .number {
            font-size: 2rem;
            font-weight: bold;
            color: var(--secondary);
        }
        
        /* Main Layout */
        .main {
            display: grid;
            grid-template-columns: 280px 1fr;
            gap: 1rem;
            padding: 1rem 2rem;
        }
        
        /* Sidebar */
        .sidebar {
            background: var(--card);
            border-radius: 12px;
            padding: 1rem;
            height: fit-content;
        }
        
        .sidebar h2 {
            font-size: 0.875rem;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 1rem;
            padding-bottom: 0.5rem;
            border-bottom: 1px solid var(--border);
        }
        
        .nav-item {
            padding: 0.75rem 1rem;
            border-radius: 8px;
            cursor: pointer;
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 0.25rem;
            transition: background 0.2s;
        }
        
        .nav-item:hover, .nav-item.active {
            background: var(--border);
        }
        
        .nav-item .badge {
            background: var(--secondary);
            color: white;
            padding: 0.25rem 0.5rem;
            border-radius: 12px;
            font-size: 0.75rem;
            font-weight: bold;
        }
        
        /* Content Area */
        .content {
            background: var(--card);
            border-radius: 12px;
            padding: 1.5rem;
        }
        
        .content-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 1.5rem;
        }
        
        .content-header h1 {
            font-size: 1.5rem;
        }
        
        .btn {
            padding: 0.75rem 1.5rem;
            border-radius: 8px;
            border: none;
            cursor: pointer;
            font-weight: 600;
            transition: all 0.2s;
        }
        
        .btn-primary {
            background: var(--secondary);
            color: white;
        }
        
        .btn-primary:hover {
            background: #a01830;
        }
        
        /* Lead Cards */
        .lead-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
            gap: 1rem;
        }
        
        .lead-card {
            background: var(--border);
            border-radius: 12px;
            padding: 1.25rem;
            border-left: 4px solid var(--secondary);
        }
        
        .lead-card.hot {
            border-left-color: var(--danger);
        }
        
        .lead-card.warm {
            border-left-color: var(--warning);
        }
        
        .lead-card.cold {
            border-left-color: var(--success);
        }
        
        .lead-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 1rem;
        }
        
        .lead-name {
            font-size: 1.25rem;
            font-weight: bold;
        }
        
        .lead-status {
            padding: 0.25rem 0.75rem;
            border-radius: 20px;
            font-size: 0.75rem;
            font-weight: 600;
            text-transform: uppercase;
        }
        
        .lead-status.scorching {
            background: var(--danger);
            color: white;
        }
        
        .lead-status.hot {
            background: var(--accent);
            color: white;
        }
        
        .lead-status.warm {
            background: var(--warning);
            color: black;
        }
        
        .lead-status.cold {
            background: var(--success);
            color: white;
        }
        
        .lead-info {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 0.75rem;
            margin-bottom: 1rem;
        }
        
        .lead-info-item {
            display: flex;
            flex-direction: column;
        }
        
        .lead-info-item label {
            font-size: 0.7rem;
            color: var(--text-muted);
            text-transform: uppercase;
        }
        
        .lead-info-item span {
            font-size: 0.95rem;
        }
        
        .lead-notes {
            background: var(--primary);
            padding: 0.75rem;
            border-radius: 8px;
            margin-bottom: 1rem;
            font-size: 0.9rem;
            color: var(--text-muted);
        }
        
        .lead-actions {
            display: flex;
            gap: 0.5rem;
        }
        
        .btn-sm {
            padding: 0.5rem 1rem;
            font-size: 0.8rem;
            border-radius: 6px;
            border: 1px solid var(--border);
            background: transparent;
            color: var(--text);
            cursor: pointer;
        }
        
        .btn-sm:hover {
            background: var(--border);
        }
        
        .btn-danger {
            border-color: var(--danger);
            color: var(--danger);
        }
        
        /* Modal */
        .modal-overlay {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(0,0,0,0.8);
            z-index: 1000;
            align-items: center;
            justify-content: center;
        }
        
        .modal-overlay.active {
            display: flex;
        }
        
