{
  "name": "throttle-bdc",
  "version": "1.0.0",
  "description": "ThrottleBDC CRM - Motorcycle Dealership BDC System",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "client": "cd client && npm start",
    "server": "node server/index.js",
    "build": "cd client && npm run build",
    "install-all": "npm install && cd client && npm install"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.11.3",
    "mongoose": "^8.0.3",
    "node-cron": "^3.0.3",
    "twilio": "^4.20.0",
    "nodemailer": "^6.9.7",
    "openai": "^4.24.1",
    "helmet": "^7.1.0",
    "express-rate-limit": "^7.1.5"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
